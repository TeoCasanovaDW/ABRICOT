# Server-only. Express backend base URL. Used only inside src/lib/api/server.ts.
BACKEND_API_URL="http://localhost:8000"

# Server-only. AI task-generation provider (Mistral) API key. Read only inside
# the AI Route Handler (app/api/ai/generate-tasks); never sent to the browser.
LLM_API_KEY="your-mistral-api-key"

# Server-only. Model name for the AI task-generation provider.
LLM_MODEL="mistral-small-latest"

# Public (optional). Absolute app URL for metadata/links. Not required for core flows.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
